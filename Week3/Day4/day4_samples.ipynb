   "source": [
    "import sympy as sp\n",
    "\n",
    "x = sp.Symbol('x')\n",
    "f = x**2\n",
    "definite_integral = sp.integrate(f, (x, 0, 2))\n",
    "indefinite_integral = sp.integrate(f, x)\n",
    "print(\"Definite Integral:\", definite_integral)\n",
    "print(\"Indefinite Integral:\", indefinite_integral)"
   ]
  }
