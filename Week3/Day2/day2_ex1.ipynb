    "import numpy as np\n",
    "\n",
    "A = np.array([[2, 3, 4], [4, 5, 6], [7, 8, 9]])\n",
    "\n",
    "determinant = np.linalg.det(A)\n",
    "inverse = np.linalg.inv(A)\n",
    "\n",
    "print(\"Determinant: \", determinant)\n",
    "print(\"Inverse: \", inverse)"
   ]
  }
