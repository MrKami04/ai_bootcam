     "text": [
      "Gradients:\n",
      "Grad X: 2*x - 4*y\n",
      "Grad Y: -4*x + 6*y\n"
     ]
    }
   ],
   "source": [
    "import sympy as sp\n",
    "\n",
    "\n",
    "# Define a multivariable function\n",
    "x, y = sp.symbols('x y')\n",
    "f = x**2 + 3*y**2 - 4*x*y\n",
    "\n",
    "# Compute partial derivatives\n",
    "grad_x = sp.diff(f, x)\n",
    "grad_y = sp.diff(f, y)\n",
    "\n",
    "print(\"Gradients:\")\n",
    "print(\"Grad X:\", grad_x)\n",
    "print(\"Grad Y:\", grad_y)"
   ]
  }
 ],
