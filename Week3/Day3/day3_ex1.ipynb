   "source": [
    "import sympy as sp\n",
    "\n",
    "# Define a function\n",
    "x = sp.Symbol('x')\n",
    "f = x**3 - 5*x + 7\n",
    "\n",
    "# Compute Derivative\n",
    "derivative = sp.diff(f, x)\n",
    "\n",
    "print(\"Function: \", f)\n",
    "print(\"Derivative: \", derivative)"
   ]
  }
 ],
