   "source": [
    "import numpy as np\n",
    "\n",
    "# Dataset\n",
    "data = [10, 20, 30, 40, 50]\n",
    "\n",
    "# Calculate Stats\n",
    "mean = np.mean(data)\n",
    "variance = np.var(data)\n",
    "std_dev = np.std(data)\n",
    "\n",
    "print(\"Mean: \", mean)\n",
    "print(\"Variance: \", variance)\n",
    "print(\"Standard Deviation: \", std_dev)"
   ]
  }
