   "source": [
    "from scipy.stats import f_oneway\n",
    "\n",
    "# Date for groups\n",
    "group1 = [10, 12, 14, 16, 18]\n",
    "group2 = [9, 11, 13, 15, 17]\n",
    "group3 = [8, 10, 12, 14, 16]\n",
    "\n",
    "# Perform ANOVA\n",
    "f_stat, p_value = f_oneway(group1, group2, group3)\n",
    "print(\"F-Statistic:\", f_stat)\n",
    "print(\"P-Value:\", p_value)"
   ]
  }
 ],
